{
  "name": "@mobilabs/kasar",
  "version": "3.0.0-alpha.0.0",
  "description": "View-powered Static Website Generator",
  "main": "index.js",
  "bin": {
    "kasar": "bin/kasar.js"
  },
  "type": "module",
  "scripts": {
    "general": " --- GENERAL ---",
    "build:js": " --- BUILDING JAVASCRIPT --- ",
    "build:css": " --- BUILDING CSS --- ",
    "build:generic": " --- BUILDING (GENERIC) --- ",
    "build:development": " --- BUILDING (DEVELOPMENT) --- ",

    "build:production": " --- BUILDING (PRODUCTION) --- ",
    "build:skeleton": "node site/.kasar/theme/scripts/build.skeleton.js $1",
    "build:project": "node site/.kasar/theme/scripts/build.project.js $1",
    "build": "npm run build:skeleton && npm run build:project && npm run npm:make:package:json",

    "testing": " --- TESTING --- ",
    "test": "cross-env NODE_ENV=test c8 --reporter=lcov mocha ./test/main.js",
    "display:coverage": "open -a safari ./coverage/lcov-report/index.html",
    "check:coverage": "c8 check-coverage --statements 100 --branches 100 --functions 100 --lines 100",
    "report": "c8 report",

    "serving": " --- SERVING --- ",
    "server:start": "node ./scripts/server.js --start --path ./site/_dist --port 8080",

    "watch:js:css": " --- WATCHING --- ",
    "watch:rebuild": "npm run build:project && node ./scripts/server.js --reload",
    "watch": "nodemon -e md,html --watch './site/webpages/**/*' --exec npm run watch:rebuild",

    "deployment": " --- DEPLOYING --- ",

    "npm:publishing": " --- PUBLISHING --- ",
    "npm:make:package:json": "node scripts/make:package:publish:json.js $1",
    "prepack": "if [[ ! -f package.publish.json ]]; then npm run npm:make:package:json ; fi && mv package.json package.dev.json && cp package.publish.json package.json",
    "postpack": "mv package.dev.json package.json",

    "doc:site:web": " --- DOCUMENTING --- ",

    "others": " --- OTHERS ---",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jclo/kasar.git"
  },
  "keywords": [
    "ES6"
  ],
  "author": {
    "name": "Mobilabs",
    "email": "contact@mobilabs.fr",
    "url": "https://www.mobilabs.fr"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jclo/kasar/issues"
  },
  "homepage": "https://github.com/jclo/kasar",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@mobilabs/kzlog": "^2.1.0",
    "@mobilabs/messenger": "^2.1.0",
    "@mobilabs/pureplus": "^2.1.0",
    "@mobilabs/rview": "^3.0.0-beta.2.0",
    "@mobilabs/spine": "^3.0.0-beta.2.0",
    "browser-sync": "^3.0.4",
    "clean-css": "^5.3.3",
    "fs-extra": "^11.3.5",
    "http-server": "^14.1.1",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.5.0",
    "markdown-it-container": "^4.0.0",
    "nodemon": "^3.1.14",
    "nopt": "^10.0.0",
    "pakket": "^1.3.0",
    "purecss": "^3.0.0",
    "shelljs": "^0.10.0",
    "terser": "^5.47.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "@mobilabs/es6lib": "3.0.0-beta.1.7"
  },
  "c8": {
    "include": [
      "index.js",
      "lib/**/*.mjs"
    ],
    "exclude": [],
    "all": false
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false
}
